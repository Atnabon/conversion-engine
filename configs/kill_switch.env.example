# Kill-switch for live outreach. DEFAULT: unset.
# When unset, every outbound message is routed to the program-staff sink.
# Live routing requires this to be set AND a reviewer-signed approval file
# at configs/live_outreach_approval.json.
# Do NOT set this during the challenge week.
#TENACIOUS_LIVE_OUTREACH=true

# --- Email (primary channel) ---
RESEND_API_KEY=
RESEND_FROM_ADDRESS=

# --- SMS (secondary, warm-lead scheduling) ---
AT_USERNAME=sandbox
AT_API_KEY=
AT_SHORTCODE=

# --- CRM ---
HUBSPOT_TOKEN=
HUBSPOT_MCP_ENDPOINT=http://localhost:3010

# --- Calendar ---
CALCOM_BASE_URL=http://localhost:3000
CALCOM_TOKEN=

# --- LLMs ---
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=

# --- Observability ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Webhook server (deploy to Render free tier — no credit card required) ---
# Set to your Render public URL once deployed, e.g. https://conversion-engine.onrender.com
# Register this URL once across all four integrations:
#   Resend:           $WEBHOOK_BASE_URL/webhooks/resend
#   Africa's Talking: $WEBHOOK_BASE_URL/webhooks/at
#   Cal.com:          $WEBHOOK_BASE_URL/webhooks/calcom
#   HubSpot:          $WEBHOOK_BASE_URL/webhooks/hubspot
WEBHOOK_BASE_URL=
# Signing secrets — set these to the values each integration dashboard shows you
RESEND_WEBHOOK_SECRET=
CALCOM_WEBHOOK_SECRET=
HUBSPOT_WEBHOOK_SECRET=

# --- Program-staff sink (default outbound destination) ---
STAFF_SINK_EMAIL=sink@tenacious-program.test
STAFF_SINK_PHONE=+251900000000
